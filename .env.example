# Kopieer naar .env en vul waarden in. (.env staat in .gitignore)

DB_HOST=127.0.0.1
DB_NAME=erp
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

TENANT_DEFAULT_SLUG=pilot_transport

# 32 bytes na base64-decode; genereer met:
# php -r "echo 'base64:'.base64_encode(random_bytes(32)).PHP_EOL;"
TENANT_SECRETS_KEY=

# SMTP (o.a. 6-cijferige inlogcode op login.php — zelfde waarden als beheer-mail)
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Beheerportaal

# Optioneel: absolute basis-URL voor links in mail (leeg = afleiden uit request)
# APP_BASE_URL=https://www.busai.nl
